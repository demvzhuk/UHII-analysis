// расчет площади (UHII > 0)
print('ПЛОЩАДЬ ОСТРОВА ТЕПЛА (UHII > 0) ДЛЯ ВСЕХ КОМБИНАЦИЙ И СТАТИСТИКА ПО ТРЕНДАМ');

var combos = [

  {dataset: SMYD1, season: 'summer', diurnal: 'daytime',   label: 'Summer Clear-sky Surface Day'},
  {dataset: SMYD1, season: 'summer', diurnal: 'nighttime', label: 'Summer Clear-sky Surface Night'},
  {dataset: SMYD1, season: 'winter', diurnal: 'daytime',   label: 'Winter Clear-sky Surface Day'},
  {dataset: SMYD1, season: 'winter', diurnal: 'nighttime', label: 'Winter Clear-sky Surface Night'},
];

combos.forEach(function(c) {
  var startM = (c.season === 'summer') ? 6 : 12;
  var endM   = (c.season === 'summer') ? 8 : 2;

  var filtered = c.dataset
    .filter(ee.Filter.eq('diurnal', c.diurnal))
    .filter(ee.Filter.calendarRange(startM, endM, 'month'));

  var image = ee.Image(ee.Algorithms.If(filtered.size().gt(0),
    filtered.mean().select('b1').multiply(0.01),
    ee.Image().rename('b1')
  )).clip(city);

  var masked = image.updateMask(image.gt(0));

  var areaDict = masked.gt(0).multiply(ee.Image.pixelArea())
    .reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: city.geometry(),
      scale: 1000,
      maxPixels: 1e13
    });

  areaDict.evaluate(function(d){
    var areaKm2 = d && d.b1 ? ee.Number(d.b1).divide(1e6) : null;
    print(c.label + ':');
    print('  Площадь UHII > 0 (км²):', areaKm2 ? areaKm2.format('%.2f') : 'нет данных');
    print('---');
  });

});

//ЭКСПОРТ ДАННЫХ
function exportUHIMap(dataset, season, diurnal, label) {
  var startM = (season === 'summer') ? 6 : 12;
  var endM   = (season === 'summer') ? 8 : 2;
  var filtered = dataset
    .filter(ee.Filter.eq('diurnal', diurnal))
    .filter(ee.Filter.calendarRange(startM, endM, 'month'));

  var image = ee.Image(ee.Algorithms.If(
    filtered.size().gt(0),
    filtered.mean().select('b1').multiply(0.01),
    ee.Image.constant(0).mask(ee.Image.constant(0)).rename('b1')
  ));

  //делаем тип Float и обрезаем по городу.
  var exportImg = image.float().clip(city); 

  Export.image.toDrive({
    image: exportImg,
    description: 'GOT_' + label.replace(/ /g, '_'),
    folder: 'UHII_Exports',
    scale: 1000,
    region: city.geometry().bounds(), 
    crs: 'EPSG:4326',
    maxPixels: 1e13,
    fileFormat: 'GeoTIFF'
  });
}

// Запуск экспорта всех карт
exportUHIMap(SMYD1, 'summer', 'daytime',   'Summer_ClearSky_Surface_Day');
