// тренды за весь период по всем слоям
function buildTrend(dataset, diurnal, season, label) {
  var years = ee.List.sequence(2003, 2020); //строит по диапазону этих дат
  var features = years.map(function(y) {
    var yNum = ee.Number(y);
    var filtered = dataset.filter(ee.Filter.eq('diurnal', diurnal));

    var seasonFilter = (season === 'summer') ?
      ee.Filter.and(ee.Filter.eq('year', yNum), ee.Filter.calendarRange(6,8,'month')) :
      ee.Filter.or(
        ee.Filter.and(ee.Filter.eq('year', yNum.subtract(1)), ee.Filter.calendarRange(12,12,'month')),
        ee.Filter.and(ee.Filter.eq('year', yNum), ee.Filter.calendarRange(1,2,'month'))
      );

    filtered = filtered.filter(seasonFilter);

    var val = ee.Image(ee.Algorithms.If(filtered.size().gt(0),
      filtered.mean().select('b1').multiply(0.01),
      ee.Image().rename('b1')
    )).reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: city.geometry(),    // используется маска
      scale: 1000,
      maxPixels: 1e13
    }).get('b1');

    return ee.Feature(null, {year: y, uhii: val});
  });

  var fc = ee.FeatureCollection(features).filter(ee.Filter.notNull(['uhii']));

  var chart = ui.Chart.feature.byFeature(fc, 'year', 'uhii')
    .setOptions({
      title: label + ' (2003–2020, внутри границы города)',
      trendlines: {0: {color: 'black', lineWidth: 3, showR2: true}},
      hAxis: {title: 'Год', format: '####'},
      vAxis: {title: 'UHII (°C)'},
      series: {0: {pointSize: 4}}
    });
  print(chart);
}

// дневные тренды (13:30 и дневной максимум SAT)
buildTrend(SMYD1, 'daytime', 'summer', 'Trend Summer Clear-sky Surface Day');
buildTrend(SMYD1, 'daytime', 'winter', 'Trend Winter Clear-sky Surface Day');


// ночные тренды (01:30 и ночной максимум SAT)
buildTrend(SMYD1, 'nighttime', 'summer', 'Trend Summer  Clear-sky Surface Night');
buildTrend(SMYD1, 'nighttime', 'winter', 'Trend Winter  Clear-sky Surface Night');

