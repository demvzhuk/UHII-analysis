// среднее значение ГОТ за весь период
function seasonalUHI(dataset, season, diurnal, label) {
  var startM = (season === 'summer') ? 6 : 12;
  var endM   = (season === 'summer') ? 8 : 2;

  var filtered = dataset
    .filter(ee.Filter.eq('diurnal', diurnal))
    .filter(ee.Filter.calendarRange(startM, endM, 'month'));

  var image = ee.Image(ee.Algorithms.If(filtered.size().gt(0),
    filtered.mean().select('b1').multiply(0.01),
    ee.Image().rename('b1')
  )).clip(city);

  // МАСКА: Показываем только если отклонение больше 0.1 градусов (и тепло, и холод)
  var threshold = 0.1; 
  var masked = image.updateMask(image.abs().gt(threshold));

  Map.addLayer(masked, visUHI, label, false);

  image.reduceRegion({
    reducer: ee.Reducer.mean().combine(ee.Reducer.stdDev(), null, true),
    geometry: city.geometry(),
    scale: 1000,
    maxPixels: 1e13
  }).evaluate(function(d){
    print(label + ' (статистика по всему городу):', d);
  });

  return image;
}

